#!/usr/bin/env bash
set -euo pipefail

# Generates an SSH key for this machine.

key_path="$HOME/.ssh/id_ed25519"

# Check for OrbStack symlinks pointing to host filesystem
if [ -d "$HOME/.ssh" ]; then
  for file in "$HOME/.ssh"/*; do
    [ -L "$file" ] || continue
    target=$(readlink "$file" 2>/dev/null || true)
    if [[ "$target" == /mnt/mac/* ]]; then
      echo "Error: Found SSH keys symlinked to host filesystem (OrbStack)."
      echo ""
      echo "Your host's SSH keys are exposed to this VM. Run this first:"
      echo ""
      echo "  isolate-orbstack"
      echo ""
      exit 1
    fi
  done
fi

# Check if key exists as a symlink (broken or otherwise) - remove it
if [ -L "$key_path" ]; then
  echo "Removing symlink at $key_path..."
  rm "$key_path"
  [ -L "$key_path.pub" ] && rm "$key_path.pub"
fi

if [ ! -f "$key_path" ]; then
  echo "Generating SSH key..."
  mkdir -p "$HOME/.ssh"
  ssh-keygen -t ed25519 -f "$key_path" -N "" -C "llmbo-sandbox"
  echo ""
fi

echo "Add this key to GitHub, GitLab, or wherever you need:"
echo ""
cat "$key_path.pub"
